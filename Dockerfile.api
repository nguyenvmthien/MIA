FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# --- Dependencies layer (cached unless pyproject.toml changes) ---
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir \
    fastapi uvicorn[standard] python-multipart \
    pydantic pydantic-settings \
    celery redis \
    sqlalchemy alembic psycopg2-binary \
    prometheus-client langsmith \
    python-dotenv httpx tenacity rich typer \
    cryptography ollama streamlit

# --- App code layer (invalidated only when src/ changes) ---
COPY src/ ./src/
COPY alembic/ ./alembic/
COPY alembic.ini ./
COPY streamlit_app.py ./
COPY train/ ./train/
RUN pip install --no-cache-dir -e . --no-deps

RUN mkdir -p data/audio data/transcripts data/tokens

ENV PYTHONUNBUFFERED=1
EXPOSE 8000
