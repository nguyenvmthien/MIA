# ── Synthetic data generation ─────────────────────────────────────────────────
# Required only for: python data_pipeline/synthetic.py --provider gemini
# Get key at: https://aistudio.google.com/apikey (free tier: 1M tokens/day)
GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://meeting:meeting@localhost:5432/meeting_agent

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── WhisperX ──────────────────────────────────────────────────────────────────
# Model size: base (fast demo) | small | medium | large-v3 (production quality)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32
WHISPER_BATCH_SIZE=16
WHISPER_LANGUAGE=en

# ── Pyannote (speaker diarization) ───────────────────────────────────────────
# Get a free token at https://huggingface.co/pyannote/speaker-diarization-3.1
# Set ENABLE_DIARIZATION=false to skip diarization (no HF_TOKEN needed)
HF_TOKEN=hf_YOUR_TOKEN_HERE
ENABLE_DIARIZATION=true

# ── LangSmith (optional — comment out to disable tracing) ────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_YOUR_KEY_HERE
LANGCHAIN_PROJECT=meeting-agent

# ── Storage ───────────────────────────────────────────────────────────────────
AUDIO_STORAGE_PATH=./data/audio
TRANSCRIPT_STORAGE_PATH=./data/transcripts

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# Fernet key for encrypting stored OAuth tokens — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left unset, a key is auto-generated and saved to data/tokens/.key (single-process only)
TOKEN_ENCRYPTION_KEY=

# ── Grafana (production) ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_ROOT_URL=http://localhost:3000

# ── PgAdmin ───────────────────────────────────────────────────────────────────
# Access the DB admin UI at http://localhost:5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ── Celery worker ─────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2     # number of parallel worker processes

# ── MLOps / Retraining ────────────────────────────────────────────────────────
# Minimum number of new human corrections before auto-retrain triggers (Celery Beat, 24h)
RETRAIN_MIN_CORRECTIONS=50

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_AUDIO_DURATION_HOURS=4
LLM_MAX_RETRIES=3
TASK_CONFIDENCE_THRESHOLD=0.6   # below this → human_review queue
