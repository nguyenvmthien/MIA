# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://meeting:meeting@localhost:5432/meeting_agent

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── WhisperX ──────────────────────────────────────────────────────────────────
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_COMPUTE_TYPE=int8   # int8 | float16 | float32
WHISPER_BATCH_SIZE=16
WHISPER_LANGUAGE=en

# ── Pyannote (speaker diarization) ───────────────────────────────────────────
# Get a free token at https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ── LangSmith (optional — comment out to disable tracing) ────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls_YOUR_KEY_HERE
LANGCHAIN_PROJECT=meeting-agent

# ── Storage ───────────────────────────────────────────────────────────────────
AUDIO_STORAGE_PATH=./data/audio
TRANSCRIPT_STORAGE_PATH=./data/transcripts

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_AUDIO_DURATION_HOURS=4
LLM_MAX_RETRIES=3
TASK_CONFIDENCE_THRESHOLD=0.6   # below this → human_review queue
